{
  "name": "api",
  "type": "module",
  "scripts": {
    "test": "bun test",
    "dev": "wrangler dev --ip 0.0.0.0 --port 8787",
    "trigger-scheduled": "curl http://127.0.0.1:8787/cdn-cgi/handler/scheduled",
    "deploy": "wrangler deploy --minify",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply glist-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply glist-db --remote"
  },
  "dependencies": {
    "@glist/views": "workspace:*",
    "@glist/shared": "workspace:*",
    "@glist/schemas": "workspace:*",
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "wrangler": "^4.71.0"
  }
}
